---
layout: layouts/base.njk
title: Blog
description: Thoughts on software development, programming, and tech
---
<h1>Blog</h1>
<p class="page-intro">Thoughts on software development, programming, and tech.</p>

<div class="posts-list">
  {% for post in collections.blog %}
  <article class="post-item">
    <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <time datetime="{{ post.date | isoDate }}">{{ post.date | dateFormat }}</time>
    <p>{{ post.data.excerpt or (post.templateContent | excerpt) }}</p>
    {% if post.data.tags %}
    <div class="post-tags">
      {% for tag in post.data.tags %}
        {% if tag != "post" %}
        <span class="tag">{{ tag }}</span>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </article>
  {% else %}
  <p>No posts yet. Check back soon!</p>
  {% endfor %}
</div>
